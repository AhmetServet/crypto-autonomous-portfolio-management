CAPM_POSTGRES_USER=postgres
CAPM_POSTGRES_PASSWORD=postgres
CAPM_POSTGRES_DB=postgres
CAPM_POSTGRES_PORT=6543

CAPM_DATABASE_URL=postgresql://postgres:postgres@localhost:6543/postgres
CAPM_DATABASE_SCHEMA=capm
CAPM_DATABASE_OHLCV_WRITE_BATCH_SIZE=500
CAPM_DATABASE_HIDE_SQL_PARAMETERS=true

CAPM_BINANCE_MODE=demo
CAPM_BINANCE_SPOT_REST_BASE_URL=https://demo-api.binance.com
CAPM_BINANCE_TIMEOUT_SECONDS=10
CAPM_BINANCE_RETRY_ATTEMPTS=3
CAPM_BINANCE_RETRY_BACKOFF_SECONDS=0.5
CAPM_BINANCE_TRUST_ENV=false
CAPM_BINANCE_API_KEY=
CAPM_BINANCE_API_SECRET=

# Set to true to block every Spot Demo submission without changing scheduler arguments.
CAPM_TRADING_EMERGENCY_STOP=false

# OpenAI-compatible LLM provider. Defaults are suitable for OpenRouter.
CAPM_LLM_BASE_URL=https://openrouter.ai/api/v1
CAPM_LLM_API_KEY=
CAPM_LLM_MODEL=
CAPM_LLM_TIMEOUT_SECONDS=30
CAPM_LLM_RETRY_ATTEMPTS=3
